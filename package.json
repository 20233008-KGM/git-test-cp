{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "human:checked": "node scripts/check-human-actions.mjs",
    "human:verify": "node scripts/verify-human-actions.mjs",
    "human:verify:strict": "node scripts/verify-human-actions.mjs --strict",
    "human:verify:json": "node scripts/verify-human-actions.mjs --json",
    "human:verify:ci": "node scripts/verify-human-actions.mjs --strict --fail-on-manual --json",
    "verify:bundle:json": "node scripts/collect-verification-report.mjs",
    "verify:bundle:save": "node scripts/collect-verification-report.mjs --out doc/for_agent/verification_report_latest.json",
    "verify:bundle:save:archive": "node scripts/collect-verification-report.mjs --out doc/for_agent/verification_report_latest.json --archive-dir doc/for_agent/verification_reports",
    "verify:bundle:save:archive:trim": "node scripts/collect-verification-report.mjs --out doc/for_agent/verification_report_latest.json --archive-dir doc/for_agent/verification_reports --keep-latest 5",
    "verify:bundle:save:archive:policy": "node scripts/collect-verification-report.mjs --out doc/for_agent/verification_report_latest.json --archive-dir doc/for_agent/verification_reports --keep-latest 5 --keep-days 14",
