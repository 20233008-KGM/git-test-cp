# CampusConnect — 로컬 개발용 환경 변수
# 이 파일을 복사해 .env 로 저장한 뒤 값을 채우세요.
# .env 는 Git에 올리지 마세요.

# Firebase (Authentication)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# RLS Beta: Firebase provider 활성화 후 true (기본 off — Alpha는 anon)
# VITE_ENABLE_SUPABASE_FIREBASE_JWT=false

# Playwright E2E (로컬·CI — Firebase 테스트 계정, 학생 권장)
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
# 교수 E2E (#12, 선택)
E2E_PROFESSOR_EMAIL=
E2E_PROFESSOR_PASSWORD=
# E2E_PORT=5173

# 통합 검증 리포트 보관 (선택)
# VERIFY_BUNDLE_KEEP_LATEST=5
# VERIFY_BUNDLE_KEEP_DAYS=14

# 런칭 전 자동 점검 (인간 없이): npm run prelaunch:check
# 인간 체크 [o] 후: npm run human:verify
# Vercel: doc/for_agent/deploy_vercel_checklist.md (H-005)
