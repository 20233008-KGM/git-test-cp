# CampusConnect — 로컬 개발용 환경 변수
# 이 파일을 복사해 .env 로 저장한 뒤 값을 채우세요.
# .env 는 Git에 올리지 마세요.

# Firebase (Authentication)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# RLS Beta: Firebase provider 활성화 후 true (기본 off — Alpha는 anon)
# VITE_ENABLE_SUPABASE_FIREBASE_JWT=false

# Playwright E2E (로컬·CI — Firebase 테스트 계정, 학생 권장)
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
# 교수 E2E (#12, 선택)
E2E_PROFESSOR_EMAIL=
E2E_PROFESSOR_PASSWORD=
# E2E_PORT=5173

# Vercel 배포 시: 위 VITE_* 를 Vercel Dashboard → Settings → Environment Variables 에 동일하게 등록
# 체크리스트: doc/for_agent/deploy_vercel_checklist.md (H-005)
